<UserControl
    x:Class="Anime4KUpscaler.views.CompressTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left column: Empty state OR File list -->
        <Grid Grid.Column="0">

            <!-- Empty state -->
            <Grid x:Name="EmptyStatePanel"
                  AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="16" MaxWidth="300">
                    <FontIcon Glyph="&#xE8F1;" FontSize="48"
                              HorizontalAlignment="Center"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="No Files Selected"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Drag &amp; drop video files here, or add them manually."
                               TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button x:Name="EmptyAddButton"
                            Content="Add Files..."
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Center"
                            Click="OnAddClicked"/>
                </StackPanel>
            </Grid>

            <!-- File list (shown when files exist) -->
            <Grid x:Name="FileListPanel" Visibility="Collapsed"
                  AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="FileCountLabel"
                           Grid.Row="0"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4"/>

                <ListView x:Name="CmpFileListView"
                          Grid.Row="1"
                          SelectionMode="Single"
                          SelectionChanged="OnSelectionChanged"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            Spacing="4" Margin="0,6,0,0">
                    <Button Content="Add" Click="OnAddClicked"/>
                    <Button x:Name="CmpRemoveBtn" Content="Remove"
                            IsEnabled="False" Click="OnRemoveClicked"/>
                    <Button x:Name="CmpClearBtn" Content="Clear"
                            IsEnabled="False" Click="OnClearClicked"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Right column: Config area OR Processing area -->
        <Grid Grid.Column="1" Margin="8,0,0,0">

            <!-- Config area -->
            <Grid x:Name="ConfigArea">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Padding="4,4,4,8">

                        <!-- Encoder -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Encoder"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <ComboBox x:Name="EncoderCombo"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnEncoderChanged">
                                <ComboBoxItem Content="HEVC (NVIDIA NVENC)"/>
                                <ComboBoxItem Content="HEVC (AMD AMF)"/>
                                <ComboBoxItem Content="HEVC (Intel QSV)"/>
                                <ComboBoxItem Content="AV1 (SVT Software)"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Quality -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="QualityLabel" Text="Quality"
                                           Style="{ThemeResource CaptionTextBlockStyle}"/>
                                <TextBlock x:Name="QualityValueLabel"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Slider x:Name="QualitySlider"
                                    Minimum="0" Maximum="100"
                                    ValueChanged="OnQualityChanged"/>
                        </StackPanel>

                        <!-- Content Type -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Content Type"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <RadioButton x:Name="LiveActionRadio"
                                             Content="Live Action"
                                             GroupName="CmpContentType"
                                             Tag="0"
                                             Checked="OnContentTypeChecked"/>
                                <RadioButton x:Name="AnimeRadio"
                                             Content="Anime"
                                             GroupName="CmpContentType"
                                             Tag="1"
                                             Checked="OnContentTypeChecked"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- B-Frames -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="B-Frames"
                                           Style="{ThemeResource CaptionTextBlockStyle}"/>
                                <TextBlock x:Name="BFramesValueLabel"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Slider x:Name="BFramesSlider"
                                    Minimum="0" Maximum="7"
                                    StepFrequency="1" TickFrequency="1"
                                    SnapsTo="Ticks"
                                    ValueChanged="OnBFramesChanged"/>
                        </StackPanel>

                        <!-- Long GOP -->
                        <CheckBox x:Name="LongGOPCheck"
                                  Content="Long GOP (larger keyframe interval)"
                                  Click="OnLongGOPChanged"/>

                        <!-- Output Directory -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Output Directory"
                                       Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="OutputDirLabel"
                                           Grid.Column="0"
                                           Text="Same as source"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Button Grid.Column="1"
                                        Content="Browse..."
                                        Click="OnBrowseOutput"/>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Grid Grid.Row="1" Margin="0,8,0,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="SummaryLabel"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Name="FileSizeLabel"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Button x:Name="StartButton"
                            Grid.Column="1"
                            Content="Compress"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="OnStartClicked"/>
                </Grid>
            </Grid>

            <!-- Processing area (overlay) -->
            <Grid x:Name="ProcessingArea" Visibility="Collapsed"
                  Padding="0,4,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Summary banner -->
                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="ProcSummaryLabel"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Name="ProcStatsLabel"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Overall progress bar -->
                <ProgressBar x:Name="OverallProgressBar"
                             Grid.Row="1"
                             Minimum="0" Maximum="100"
                             Margin="0,0,0,8"/>

                <!-- Per-job list -->
                <ScrollViewer Grid.Row="2">
                    <StackPanel x:Name="CmpJobList" Spacing="4"/>
                </ScrollViewer>

                <!-- Action buttons -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">
                    <Button x:Name="ReturnBtn"
                            Content="Return to Configuration"
                            IsEnabled="False"
                            Click="OnReturnClicked"/>
                    <Button x:Name="CancelBtn"
                            Content="Cancel"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="OnCancelClicked"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
