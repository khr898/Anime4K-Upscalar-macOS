<UserControl
    x:Class="Anime4KUpscaler.views.UpscaleTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Anime4KUpscaler.views"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left column: EmptyState OR FileListPanel -->
        <Grid Grid.Column="0">
            <views:EmptyState  x:Name="EmptyStateView"  Visibility="Visible"/>
            <views:FileListPanel x:Name="FileListView"  Visibility="Collapsed"/>
        </Grid>

        <!-- Right column: Config area OR ProcessingPanel -->
        <Grid Grid.Column="1" Margin="8,0,0,0">

            <!-- Config area (ModePicker + ConfigPanel + footer) -->
            <Grid x:Name="ConfigArea" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <views:ModePicker x:Name="ModePickerView" Grid.Row="0" Margin="0,0,0,8"/>
                <views:ConfigurationPanel x:Name="ConfigPanelView" Grid.Row="1"/>

                <!-- Footer -->
                <Grid Grid.Row="2" Margin="0,8,0,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="SummaryLabel"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Name="FileSizeLabel"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Button x:Name="StartButton"
                            Grid.Column="1"
                            Content="Start Upscaling"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="OnStartClicked"/>
                </Grid>
            </Grid>

            <!-- Processing panel -->
            <views:ProcessingPanel x:Name="ProcessingView" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
